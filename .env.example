TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TARGET_CHAT_ID=
CHANNEL_USERNAMES=cnn,bbcnews,reuters

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# UTC HH:MM when the bot sends yesterday summary
SUMMARY_SEND_TIME_UTC=00:10

# LLM/ranking tuning
SUMMARY_TOP_K=12
SUMMARY_MAX_ITEMS=80
SUMMARY_MAX_CHARS_PER_ITEM=700

# Keep at most this many days in local sqlite storage
RETENTION_DAYS=7

# Container internal path for session + sqlite
DATA_DIR=/news_data

LOG_LEVEL=INFO
